# JoelCashKing production variables

NODE_ENV=production
APP_NAME=JoelCashKing

# Railway sets PORT automatically. For local use you can set:
PORT=3000

# Required in production. Use a long random value.
ADMIN_KEY=CHANGE_ME_LONG_RANDOM_ADMIN_PASSWORD

# Optional. Public URL of your app.
PUBLIC_URL=https://your-app.up.railway.app

# Optional. Comma-separated origins allowed by CORS.
# Example: https://your-domain.com,https://your-app.up.railway.app
ALLOWED_ORIGIN=

# Persistent storage.
# On Railway, create a Volume and mount it to /data, then keep:
DATA_DIR=/data

# Optional advanced override. Normally leave disabled.
# DB_FILE=/data/db.json


# Offerwall / encuestas
# Ejemplo:
# OFFERWALL_NAME=Offerway
# OFFERWALL_URL=https://tu-offerwall.com/wall?user_id={{USER_ID}}&username={{USERNAME}}&email={{EMAIL}}
OFFERWALL_NAME=Offerway
OFFERWALL_URL=


# Anuncios recompensados
REQUIRED_ADS_PER_REWARD=5


# ayeT-Studios Rewarded Video HTML5
# Crea en ayeT: Placement Type = Website, AdSlot Type = Rewarded Video
AYET_PLACEMENT_ID=
AYET_ADSLOT_NAME=
AYET_OPTIONAL_PARAMETER=joelcashking

# Opcional pero recomendado para validar signature del callback clientside.
# Lo encuentras en Dashboard > Account Settings > API Key.
AYET_API_KEY=


# Modo de recompensa ayeT:
# s2s = recomendado, espera callbacks servidor a servidor
# client = usa callbackRewarded del navegador
AYET_REWARD_MODE=s2s


# Monetag / proveedor Direct Link Ads
# Modo antiguo compatible:
DIRECT_AD_URL=

# Modo nuevo recomendado: varios botones Direct Ads
DIRECT_AD_LINK_1_NAME=Direct Ad 1
DIRECT_AD_LINK_1_URL=https://omg10.com/4/10951161
DIRECT_AD_LINK_1_REWARD_COINS=5
DIRECT_AD_LINK_1_WAIT_SECONDS=30
DIRECT_AD_LINK_1_COOLDOWN_SECONDS=180

DIRECT_AD_LINK_2_NAME=Direct Ad 2
DIRECT_AD_LINK_2_URL=
DIRECT_AD_LINK_2_REWARD_COINS=5
DIRECT_AD_LINK_2_WAIT_SECONDS=30
DIRECT_AD_LINK_2_COOLDOWN_SECONDS=180

DIRECT_AD_WAIT_SECONDS=30
DIRECT_AD_COOLDOWN_SECONDS=180
DIRECT_AD_REWARD_COINS=5
